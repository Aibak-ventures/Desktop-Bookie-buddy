# Staging Environment Variables
ENV=staging
BASE_URL=https://staging-api.bookingapp.com
BUCKET_BASE_URL=https://staging-storage.bookingapp.com
HEALTH_CHECK_URL=https://staging-api.bookingapp.com/health
SOCKET_URL=wss://staging-api.bookingapp.com/ws

# Payment Keys (Staging)
RAZORPAY_KEY=rzp_test_staging_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_staging_stripe_key

# Debug & Monitoring
SENTRY_DSN=https://your-staging-sentry-dsn@sentry.io/project-id
ENABLE_DEBUG_LOGS=true
ENABLE_NETWORK_LOGS=true
ENABLE_MOCK_DATA=false

# App Update URLs
APP_UPDATE_URL_ANDROID=https://play.google.com/store/apps/details?id=com.bookingapp.staging
APP_UPDATE_URL_IOS=https://apps.apple.com/app/booking-app-staging/id555666777

# API Keys
GOOGLE_MAPS_API_KEY=staging_google_maps_key_here
FIREBASE_API_KEY=staging_firebase_key_here

# Feature Flags
ENABLE_BIOMETRIC_AUTH=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_NEW_UI=true

# Database
DATABASE_NAME=booking_app_staging.db

# App Info
APP_NAME=Booking App (Staging)
APP_SUFFIX=.staging
