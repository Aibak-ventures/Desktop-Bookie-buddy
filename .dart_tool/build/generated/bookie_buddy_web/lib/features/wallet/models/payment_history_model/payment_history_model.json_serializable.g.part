        _$MonthlyPaymentsModelImpl instance) =>
    <String, dynamic>{
      'month': instance.month,
      'daily_payments': instance.dailyPayments,
    };

_$DailyPaymentsModelImpl _$$DailyPaymentsModelImplFromJson(
        Map<String, dynamic> json) =>
    _$DailyPaymentsModelImpl(
      date: json['date'] as String,
      payments: (json['payments'] as List<dynamic>)
          .map((e) => PaymentModel.fromJson(e as Map<String, dynamic>))
