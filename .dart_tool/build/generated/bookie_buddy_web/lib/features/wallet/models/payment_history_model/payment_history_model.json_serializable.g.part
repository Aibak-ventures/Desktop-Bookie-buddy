        Map<String, dynamic> json) =>
    _$MonthlyPaymentsModelImpl(
      month: json['month'] as String,
      dailyPayments: (json['daily_payments'] as List<dynamic>)
          .map((e) => DailyPaymentsModel.fromJson(e as Map<String, dynamic>))
          .toList(),
    );

