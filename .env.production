# Production Environment Variables - Bookie Buddy
ENV=production
BASE_URL=https://flutter.bookiebuddy.in
BUCKET_BASE_URL=https://flutter.bookiebuddy.in
HEALTH_CHECK_URL=https://flutter.bookiebuddy.in/health
SOCKET_URL=wss://flutter.bookiebuddy.in/ws

# Payment Keys (Production)
RAZORPAY_KEY=rzp_live_prod_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_prod_stripe_key

# Debug & Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
ENABLE_DEBUG_LOGS=false
ENABLE_NETWORK_LOGS=false
ENABLE_MOCK_DATA=false

# App Update URLs
APP_UPDATE_URL_ANDROID=https://play.google.com/store/apps/details?id=com.bookingapp
APP_UPDATE_URL_IOS=https://apps.apple.com/app/booking-app/id987654321

# API Keys
GOOGLE_MAPS_API_KEY=prod_google_maps_key_here
FIREBASE_API_KEY=prod_firebase_key_here

# Feature Flags
ENABLE_BIOMETRIC_AUTH=true
ENABLE_PUSH_NOTIFICATIONS=true
ENABLE_NEW_UI=true

# Database
DATABASE_NAME=booking_app.db

# App Info
APP_NAME=Booking App
APP_SUFFIX=
